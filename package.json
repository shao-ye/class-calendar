{
  "name": "class-calendar",
  "version": "0.1.0",
  "description": "孩子每日课程、课包消耗和上课记录的小型日历工具。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shao-ye/class-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/shao-ye/class-calendar/issues"
  },
  "homepage": "https://github.com/shao-ye/class-calendar#readme",
  "keywords": [
    "calendar",
    "course",
    "vue",
    "cloudflare-pages",
    "d1",
    "r2"
  ],
  "type": "module",
  "scripts": {
    "ui": "vite",
    "server": "wrangler pages dev dist --port 8788",
    "build": "vite build",
    "deploy": "vite build && wrangler pages deploy dist --project-name class-calendar",
    "db:init": "wrangler d1 execute class_calendar --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute class_calendar --local --file=./seed.sql",
    "db:init:remote": "wrangler d1 execute class_calendar --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute class_calendar --remote --file=./seed.sql",
    "genhash": "node scripts/gen-hash.mjs"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  }
}
