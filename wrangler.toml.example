name = "class-calendar"
pages_build_output_dir = "dist"
compatibility_date = "2024-11-01"

# D1 数据库绑定。复制本文件为 wrangler.toml，并把 database_id 换成你自己的库 ID
# （执行 `wrangler d1 create class_calendar` 获取）
[[d1_databases]]
binding = "DB"
database_name = "class_calendar"
database_id = "YOUR_D1_DATABASE_ID"

# R2 存储桶绑定（照片二进制）
[[r2_buckets]]
binding = "PHOTOS"
bucket_name = "class-photos"
